# Database (Docker Compose MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cultrux
DB_USER=cultrux
DB_PASSWORD=cultrux

# Backend
PORT=3000
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# Stripe Test Mode
# 1) Dashboard → Developers → API keys → Secret key (sk_test_…)
STRIPE_SECRET_KEY=sk_test_your_key_here
# 2) From CLI only: stripe listen --forward-to localhost:3000/webhooks/stripe → whsec_…
#    Never put sk_test_… in STRIPE_WEBHOOK_SECRET
STRIPE_WEBHOOK_SECRET=whsec_from_stripe_listen
# Presentment currency (amounts in integer paise when inr)
STRIPE_CURRENCY=inr
